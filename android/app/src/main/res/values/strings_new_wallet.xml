    <string name="new_wallet_flow_wallet_export_qr_help_title">How do I get my wallet export QR code?</string>
    <string name="new_wallet_flow_qr_help_advanced_tools">1. Go to \'Advanced / Tools\'</string>
    <string name="new_wallet_flow_qr_help_export_generic_json">2. Export Wallet &gt; Generic JSON</string>
    <string name="new_wallet_flow_qr_help_press_enter_qr">3. Press the \'Enter\' button, then the \'QR\' button</string>
    <string name="new_wallet_flow_qr_help_scan_generated_qr">4. Scan the Generated QR code</string>
    <string name="new_wallet_flow_qr_help_export_descriptor">2. Export Wallet &gt; Descriptor</string>
    <string name="new_wallet_flow_qr_help_press_enter_select_wallet_type">3. Press the Enter (&#10003;) and select your wallet type</string>
    <string name="new_wallet_flow_qr_help_sparrow_settings">1. Click on Settings, in the left side bar</string>
    <string name="new_wallet_flow_qr_help_sparrow_export">2. Click on \'Export...\' button at the bottom</string>
    <string name="new_wallet_flow_qr_help_sparrow_show_descriptor">3. Under \'Output Descriptor\' click the \'Show...\' button</string>
    <string name="new_wallet_flow_qr_help_sparrow_show_bbqr">4. Make sure \'Show BBQr\' is selected</string>
    <string name="new_wallet_flow_qr_help_scan_generated_qr_lower">5. Scan the generated QR code</string>
    <string name="new_wallet_flow_qr_help_hardware_settings">1. In your hardware wallet, go to settings</string>
    <string name="new_wallet_flow_qr_help_look_for_export">2. Look for \'Export\'</string>
    <string name="new_wallet_flow_qr_help_select_export_format">3. Select \'Generic JSON\', \'Sparrow\', \'Electrum\', and many other formats should also work</string>
    <string name="new_wallet_flow_qr_help_generate_qr">4. Generate QR code</string>
    <string name="new_wallet_flow_qr_help_scan_generated_qr_step_5">5. Scan the Generated QR code</string>

    <string name="new_wallet_flow_nfc_help_title">How do I import using NFC?</string>
    <string name="new_wallet_flow_nfc_help_enable_nfc">1. Enable NFC by going to \'Settings\' &gt; \'Hardware On/Off\' &gt; \'NFC Sharing\'</string>
    <string name="new_wallet_flow_nfc_help_advanced_tools">2. Go to \'Advanced / Tools\'</string>
    <string name="new_wallet_flow_nfc_help_export_descriptor">3. Export Wallet &gt; \'Descriptor\' &gt; \'Segwit P2WPKH\'</string>
    <string name="new_wallet_flow_nfc_help_press_enter_nfc">4. Press the \'Enter\' button, then the \'NFC\' button</string>
    <string name="new_wallet_flow_nfc_help_bring_phone_top">5. Bring the phone to the top of the screen</string>
    <string name="new_wallet_flow_nfc_help_bring_phone_8_button">5. Bring the phone to the to the coldcard near the 8 button</string>
