               BlueprintIdentifier = "C0A000052EF0000000000001"
               BuildableName = "CoveUITests.xctest"
               BlueprintName = "CoveUITests"
               ReferencedContainer = "container:Cove.xcodeproj">
            </BuildableReference>
         </TestableReference>
      </Testables>
